{
  "name": "iconcat-monorepo",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "build": "turbo run build",
    "build:packages": "turbo run build --filter='./packages/*'",
    "build:docs": "turbo run build --filter=@iconcat/site...",
    "bench:extractor": "pnpm --filter @iconcat/extractor run bench",
    "bench:extractor:memory": "pnpm --filter @iconcat/extractor run bench:memory",
    "bench:extractor:persistent": "pnpm --filter @iconcat/extractor run bench:persistent",
    "dev": "pnpm --filter @iconcat/site run dev",
    "dev:iconcat": "node scripts/dev/start.mjs",
    "dev:page-mode": "node scripts/dev/page-mode-dev.mjs",
    "preview:page-mode": "node scripts/dev/page-mode-preview.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "turbo run test --filter=@iconcat/core --filter=@iconcat/extractor --filter=@iconcat/tailwind --filter=@iconcat/vite",
    "test:example-page-mode": "vitest run --config vitest.example-page-mode.config.ts",
    "typecheck": "turbo run typecheck",
    "test:production-previews": "vitest run --config vitest.production-previews.config.ts",
    "verify:production-previews": "vitest run --config vitest.production-previews.config.ts",
    "verify:production-previews:update": "node scripts/verify-production-previews.mjs --update",
    "changeset": "changeset",
    "changeset:publish": "changeset publish"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.4.1",
    "@changesets/cli": "^2.27.8",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/types": "^19.8.1",
    "@eslint-react/eslint-plugin": "^1.53.1",
    "@jannajs/lint": "3.1.4",
    "@types/node": "^26.0.1",
    "@typescript/native-preview": "7.0.0-dev.20260626.1",
    "@typescript/native-preview-linux-x64": "7.0.0-dev.20260626.1",
    "eslint": "^9.39.4",
    "eslint-plugin-format": "^1.5.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "tsdown": "^0.22.3",
    "turbo": "^2.10.0",
    "typescript": "6.0.3"
  },
  "pnpm": {
    "overrides": {
      "eslint-plugin-es-x": "^9.7.0",
      "eslint-plugin-n": "^18.2.1",
      "eslint-plugin-regexp": "^3.1.0",
      "typescript": "6.0.3"
    }
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
