{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@iconcat/adapter-utils/next-app-router": ["../adapter-utils/src/next-app-router.ts"],
      "@iconcat/adapter-utils": ["../adapter-utils/src"],
      "@iconcat/core": ["../core/src"],
      "@iconcat/extractor": ["./src"],
      "@iconcat/presets": ["../presets/src"]
    },
    "resolveJsonModule": true,
    "types": ["node"],
    "allowJs": false,
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": true,
    "outDir": "./dist",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": ["src", "test/**/*.test.ts", "bench/**/*.bench.ts"]
}
