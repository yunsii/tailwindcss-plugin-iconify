{
  "name": "@iconcat/extractor",
  "type": "module",
  "version": "0.1.0",
  "description": "Entry-driven icon catalog extractor for Iconcat.",
  "author": "Yuns <yuns.xie@qq.com>",
  "license": "MIT",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./rolldown": {
      "import": {
        "types": "./dist/rolldown.d.mts",
        "default": "./dist/rolldown.mjs"
      },
      "require": {
        "types": "./dist/rolldown.d.cts",
        "default": "./dist/rolldown.cjs"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/vite.d.mts",
        "default": "./dist/vite.mjs"
      },
      "require": {
        "types": "./dist/vite.d.cts",
        "default": "./dist/vite.cjs"
      }
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "bench": "vitest bench --run --config vitest.config.ts",
    "bench:memory": "node --expose-gc --import tsx bench/memory.ts",
    "bench:persistent": "node --import tsx bench/persistent-cache.ts",
    "build": "tsdown",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsgo --noEmit --rootDir ../.."
  },
  "dependencies": {
    "@iconcat/core": "workspace:*",
    "esbuild": "^0.24.0",
    "fast-glob": "^3.3.2",
    "pathe": "^1.1.2"
  },
  "optionalDependencies": {
    "rolldown": "^1.1.3"
  },
  "devDependencies": {
    "vite": "^5.4.5",
    "vitest": "^2.1.1"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
