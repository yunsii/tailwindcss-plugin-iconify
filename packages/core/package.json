{
  "name": "@iconcat/core",
  "type": "module",
  "version": "0.1.0",
  "description": "Core catalog and icon parsing utilities for Iconcat.",
  "author": "Yuns <yuns.xie@qq.com>",
  "license": "MIT",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@iconify/utils": "^2.3.0"
  },
  "devDependencies": {
    "vite": "^5.4.5",
    "vitest": "^2.1.1"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
