{
  "name": "iconcat",
  "type": "module",
  "version": "0.1.0",
  "description": "CLI for Iconcat entry-driven icon catalog extraction.",
  "author": "Yuns <yuns.xie@qq.com>",
  "license": "MIT",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./runtime": {
      "import": {
        "types": "./dist/runtime.d.mts",
        "default": "./dist/runtime.mjs"
      }
    }
  },
  "bin": {
    "iconcat": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo --noEmit --rootDir ../.."
  },
  "dependencies": {
    "@iconcat/extractor": "workspace:*",
    "jiti": "^2.6.1",
    "pathe": "^1.1.2"
  },
  "devDependencies": {
    "vite": "^5.4.5"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
