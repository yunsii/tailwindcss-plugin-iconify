{
  "name": "tailwindcss-plugin-iconify",
  "type": "module",
  "version": "2.1.0",
  "description": "Compatibility package for @iconcat/tailwind.",
  "author": "Yuns <yuns.xie@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/yunsii/tailwindcss-plugin-iconify#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/yunsii/tailwindcss-plugin-iconify",
    "directory": "packages/compat-tailwindcss-plugin-iconify"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/plugin.d.mts",
        "default": "./dist/plugin.mjs"
      },
      "require": {
        "types": "./dist/plugin.d.cts",
        "default": "./dist/plugin.cjs"
      }
    },
    "./local-icon-sets": {
      "import": {
        "types": "./dist/local-icon-sets.d.mts",
        "default": "./dist/local-icon-sets.mjs"
      },
      "require": {
        "types": "./dist/local-icon-sets.d.cts",
        "default": "./dist/local-icon-sets.cjs"
      }
    },
    "./figma-icon-sets": {
      "import": {
        "types": "./dist/figma-icon-sets.d.mts",
        "default": "./dist/figma-icon-sets.mjs"
      },
      "require": {
        "types": "./dist/figma-icon-sets.d.cts",
        "default": "./dist/figma-icon-sets.cjs"
      }
    },
    "./figma-icon-sets/node": {
      "import": {
        "types": "./dist/figma-icon-sets-node.d.mts",
        "default": "./dist/figma-icon-sets-node.mjs"
      },
      "require": {
        "types": "./dist/figma-icon-sets-node.d.cts",
        "default": "./dist/figma-icon-sets-node.cjs"
      }
    }
  },
  "main": "./dist/plugin.mjs",
  "module": "./dist/plugin.mjs",
  "types": "./dist/plugin.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo --noEmit --rootDir ../.."
  },
  "peerDependencies": {
    "tailwindcss": ">=3"
  },
  "dependencies": {
    "@iconcat/tailwind": "workspace:*"
  },
  "devDependencies": {
    "vite": "^5.4.5"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
