{
  "name": "@iconcat/vite",
  "type": "module",
  "version": "0.1.0",
  "description": "Vite adapter for Iconcat catalog CSS.",
  "author": "Yuns <yuns.xie@qq.com>",
  "license": "MIT",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsgo --noEmit --rootDir ../.."
  },
  "peerDependencies": {
    "vite": ">=5"
  },
  "dependencies": {
    "@iconcat/adapter-utils": "workspace:*",
    "@iconcat/extractor": "workspace:*"
  },
  "devDependencies": {
    "vite": "^5.4.5",
    "vitest": "^2.1.1"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
